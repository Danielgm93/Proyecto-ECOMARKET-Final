# =====================================================================
# Selección de backend de LLM
# =====================================================================
# "ollama"    → modelo local Qwen (NO requiere API key, NO tiene costo)
# "anthropic" → Claude vía API de Anthropic (requiere API key)
LLM_BACKEND=ollama

# --- Configuración del backend local (Ollama) ------------------------
# Modelo recomendado para una RTX 3050 (6 GB VRAM): qwen2.5:7b
# Alternativa más ligera y rápida (si el 7B va lento): qwen2.5:3b
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434

# --- Configuración del backend Anthropic (opcional) ------------------
# Solo se usa si LLM_BACKEND=anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- LangSmith (opcional, para trazabilidad avanzada) ----------------
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_...
# LANGCHAIN_PROJECT=ecomarket-agent
